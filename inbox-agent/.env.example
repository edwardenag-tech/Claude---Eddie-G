# ─────────────────────────────────────────────
#  Inbox Agent — Environment Variable Template
#  Copy this file to .env and fill in values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────

# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Microsoft Azure (Outlook / Microsoft 365)
# App: "Landlord Update Agent"
AZURE_CLIENT_ID=077f47ad-e210-48dd-997f-5ca413ca735c
AZURE_TENANT_ID=255db1c7-fd44-4604-9aea-032bd2883c0d

# Email addresses
USER_GMAIL=edwardenag@gmail.com
USER_OUTLOOK=edward@ibproperty.com.au

# Comma-separated list of addresses to receive the morning briefing
NOTIFY_EMAILS=edwardenag@gmail.com,edward@ibproperty.com.au

# Gmail OAuth2 credentials file (downloaded from Google Cloud Console)
# See README.md for instructions on how to obtain this file
GMAIL_CREDENTIALS_PATH=gmail_credentials.json

# Auto-generated token files (created on first run — do not edit manually)
GMAIL_TOKEN_PATH=gmail_token.json
MSAL_TOKEN_CACHE_PATH=msal_token_cache.json
